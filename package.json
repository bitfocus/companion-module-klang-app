{
    "name": "companion-module-klang-app",
    "version": "2.0.0",
    "type": "module",
    "main": "dist/main.js",
    "typings": "dist/main.d.ts",
    "license": "MIT",
    "repository": "https://github.com/bitfocus/companion-module-klang-app",
    "scripts": {
        "postinstall": "husky",
        "format": "prettier -w .",
        "package": "run build && companion-module-build",
        "build": "rimraf dist && run build:main",
        "build:main": "tsc -p tsconfig.build.json",
        "dev": "tsc -p tsconfig.build.json --watch",
        "lint:raw": "eslint",
        "lint": "run lint:raw ."
    },
    "engines": {
        "node": "^22.20",
        "yarn": "^4"
    },
    "files": [
        "README.md",
        "CHANGELOG.md",
        "dist",
        "generated",
        "assets"
    ],
    "dependencies": {
        "@companion-module/base": "~2.0.3",
        "companion-module-utils": "^0.5.0",
        "osc": "^2.4.5"
    },
    "devDependencies": {
        "@companion-module/tools": "^2.7.1",
        "@types/node": "^22.19.3",
        "eslint": "^9.39.2",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.7.4",
        "rimraf": "^6.1.2",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.51.0"
    },
    "prettier": "@companion-module/tools/.prettierrc.json",
    "lint-staged": {
        "*.{css,json,md,scss}": [
            "prettier --write"
        ],
        "*.{ts,tsx,js,jsx}": [
            "yarn lint:raw --fix"
        ]
    },
    "packageManager": "yarn@4.12.0"
}
